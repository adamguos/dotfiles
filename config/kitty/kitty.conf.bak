# Put the following lines in your ~/.config/kitty/kitty.conf
foreground #7a9a7a
background #0d1410
color0 #253828
color1 #7a9a7a
color2 #7a9a7a
color3 #7a9a7a
color4 #7a9a7a
color5 #7a9a7a
color6 #7a9a7a
color7 #7a9a7a
color8 #253828
color9 #9abb9a
color10 #9abb9a
color11 #7a9a7a
color12 #7a9a7a
color13 #7a9a7a
color14 #7a9a7a
color15 #9abb9a
cursor #9abb9a
cursor_text_color #0d1410
selection_foreground none
selection_background #1a2a1a
tab_bar_background #070b08
active_tab_foreground #7a9a7a
active_tab_background #0d1410
inactive_tab_foreground #253828
inactive_tab_background #090f0c
active_border_color #7a9a7a
inactive_border_color #2a3a2a

font_size               13.0
hide_window_decorations no
modify_font cell_width  100%
placement_strategy      bottom

# BEGIN_KITTY_FONTS
font_family      family="Google Sans Code"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
